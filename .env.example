# 用于 API 密钥存储的服务器加密密钥（生成方式：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"）
ENCRYPTION_KEY=your-64-char-hex-key-here

# 服务器端口（默认：3001）
PORT=3001

# 仅限 Docker：容器端口发布到哪个主机接口。
# 默认为 127.0.0.1，因此仪表盘/API 只能从运行 Docker 的本机访问。
# 如需向局域网内的其他设备开放（例如通过 http://192.168.1.x:3001 访问的 Raspberry Pi），
# 请设置 HOST_BIND=0.0.0.0。
# 仅在可信网络上执行此操作——该代理为单用户模式，仅通过统一 API 密钥进行保护。
# HOST_BIND=0.0.0.0

# 每个客户端 IP 每分钟最大 /v1 代理请求数（默认：120）。设置为 0 可禁用代理速率限制。
# PROXY_RATE_LIMIT_RPM=120

# 请求分析数据保留设置。将任一值设为 0 可禁用该限制。
REQUEST_ANALYTICS_RETENTION_DAYS=90
REQUEST_ANALYTICS_MAX_ROWS=100000

# 模型切换时的上下文交接。启用后，当会话从一个模型切换到另一个模型时（例如回退后），
# FreeLLMAPI 会在出站请求中注入一条紧凑的系统消息。默认关闭。
# FREELLMAPI_CONTEXT_HANDOFF=on_model_switch

# 允许从浏览器调用 API 的额外来源，以逗号分隔。
# 默认允许 localhost:5173、127.0.0.1:5173、[::1]:5173，用于 Vite 开发仪表盘。
# 仅当仪表盘和 API 部署在不同主机时才需设置此项（例如 http://my-server.local）。
# DASHBOARD_ORIGINS=http://my-server.local,http://192.168.1.50
